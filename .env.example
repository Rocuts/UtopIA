# UtopIA — env template
# Pull values from Vercel after `vercel integration add ...` with:
#   vercel env pull .env.local --yes

# OpenAI (chat orchestrator, financial pipelines, OCR, Realtime voice, RAG embeddings)
OPENAI_API_KEY=

# Tavily (web search tool)
TAVILY_API_KEY=

# Agent mode: 'orchestrated' (multi-agent) | 'legacy' (monolithic)
UTOPIA_AGENT_MODE=orchestrated

# --- Optional model overrides (see src/lib/config/models.ts) ---
# OPENAI_MODEL_CHAT=gpt-4o-mini
# OPENAI_MODEL_FINANCIAL=gpt-4o-mini
# OPENAI_MODEL_CLASSIFIER=gpt-4o-mini
# OPENAI_MODEL_OCR=gpt-4o

# --- Postgres (Neon via Vercel Marketplace) ---
# Auto-provisioned by `vercel integration add neon`.
# DATABASE_URL is the Neon connection string with pooling.
DATABASE_URL=

# --- Legacy / unused ---
# AI_GATEWAY_API_KEY=  # earlier iteration, no longer used
