# UtopIA — env template
# Pull values from Vercel after `vercel integration add ...` with:
#   vercel env pull .env.local --yes

# OpenAI (chat orchestrator, financial pipelines, OCR, Realtime voice, RAG embeddings)
OPENAI_API_KEY=

# Tavily (web search tool)
TAVILY_API_KEY=

# Agent mode: 'orchestrated' (multi-agent) | 'legacy' (monolithic)
UTOPIA_AGENT_MODE=orchestrated

# --- Optional model overrides (see src/lib/config/models.ts) ---
# OPENAI_MODEL_CHAT=gpt-4o-mini
# OPENAI_MODEL_FINANCIAL=gpt-4o-mini
# OPENAI_MODEL_CLASSIFIER=gpt-4o-mini
# OPENAI_MODEL_OCR=gpt-4o

# --- Postgres (Neon via Vercel Marketplace) ---
# Auto-provisioned by `vercel integration add neon`.
#
# IMPORTANTE (Ola 0.A): el runtime usa `pg.Pool` + `drizzle-orm/node-postgres`
# sobre TCP. DATABASE_URL DEBE apuntar al endpoint POOLED de Neon — el host
# contiene el sufijo `-pooler`, p.ej:
#   postgres://user:pwd@ep-xxx-pooler.us-east-1.aws.neon.tech/dbname?sslmode=require
# Si apunta al endpoint directo (sin `-pooler`) cada instancia Fluid Compute
# abrira su propio pool y agotaras los slots de Neon en produccion.
# Ver docs/MIGRATION_DRIVER.md para mas detalle.
DATABASE_URL=

# --- Ola 1+1 Élite — feature flags (todos OFF por defecto en producción) ---
# Encender uno por uno post-smoke. Ver docs/MVP_DECISIONS_DEFERRED.md.
UTOPIA_ENABLE_TAX_ENGINE=
UTOPIA_ENABLE_OCR_PROMOTE=
UTOPIA_ENABLE_BANK_RECON=
UTOPIA_ENABLE_AUTO_ADJUSTMENTS=
UTOPIA_ENABLE_MONTHLY_CLOSE_WORKFLOW=
UTOPIA_ENABLE_NOTIFICATIONS=

# --- Ola 1+1 Élite — secretos / proveedores ---
# Internal secret usado por WS5 workflow al llamar a /api/notifications/dispatch.
# Generar con: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
UTOPIA_INTERNAL_SECRET=

# Resend (WS6 — email transaccional). Sin valor ⇒ dispatch responde 'channel_disabled' gracefully.
RESEND_API_KEY=
# Remitente del email; default 'UtopIA <onboarding@resend.dev>' si vacío
NOTIFICATIONS_FROM=

# Vercel Blob (WS5 — PDF élite del cierre mensual). Auto-provisionado por `vercel integration add blob`.
BLOB_READ_WRITE_TOKEN=

# --- Legacy / unused ---
# AI_GATEWAY_API_KEY=  # earlier iteration, no longer used
