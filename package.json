{
  "name": "one-plus-one",
  "displayName": "1+1",
  "version": "0.1.0",
  "description": "1+1 — Directorio Ejecutivo Digital impulsado por IA para empresas colombianas: estrategia contable, tributaria y financiera en un solo centro de mando.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:ingest": "tsx src/lib/rag/ingest.ts",
    "db:ingest:docs": "tsx src/lib/rag/ingest.ts --docs-only",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- tsx scripts/db-migrate.ts",
    "db:seed-calendar": "dotenv -e .env.local -- tsx scripts/seed-verified-calendar.ts",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio"
  },
  "dependencies": {
