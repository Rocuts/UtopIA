    "@langchain/textsplitters": "^1.0.1",
    "@neondatabase/serverless": "^1.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@vercel/blob": "^2.0.0",
    "@vercel/functions": "^3.0.0",
    "ai": "^6.0.168",
