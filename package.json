    "hnswlib-node": "^3.0.0",
    "jspdf": "^4.2.1",
    "langchain": "^1.2.30",
    "lenis": "^1.3.18",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.12.0",
    "motion": "^12.35.2",
    "next": "^16.2.2",
